# Pinned source versions + sha256 for the static QEMU build.
# Used by build-macos.sh / lib/deps.sh. Update deliberately.

QEMU_VERSION=11.0.1
LIBFFI_VERSION=3.5.2
PCRE2_VERSION=10.47
GLIB_VERSION=2.88.1
LIBSLIRP_VERSION=4.9.3
ZSTD_VERSION=1.5.7
PIXMAN_VERSION=0.46.4   # fallback only, if QEMU cannot --disable-pixman

# Source URLs (release tarballs; no autotools regen needed).
QEMU_URL="https://download.qemu.org/qemu-${QEMU_VERSION}.tar.xz"
LIBFFI_URL="https://github.com/libffi/libffi/releases/download/v${LIBFFI_VERSION}/libffi-${LIBFFI_VERSION}.tar.gz"
PCRE2_URL="https://github.com/PCRE2Project/pcre2/releases/download/pcre2-${PCRE2_VERSION}/pcre2-${PCRE2_VERSION}.tar.bz2"
GLIB_URL="https://download.gnome.org/sources/glib/2.88/glib-${GLIB_VERSION}.tar.xz"
LIBSLIRP_URL="https://gitlab.freedesktop.org/slirp/libslirp/-/archive/v${LIBSLIRP_VERSION}/libslirp-v${LIBSLIRP_VERSION}.tar.gz"
ZSTD_URL="https://github.com/facebook/zstd/releases/download/v${ZSTD_VERSION}/zstd-${ZSTD_VERSION}.tar.gz"

# sha256 of the downloaded tarballs (verified at fetch time).
